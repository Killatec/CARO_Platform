# CARO MQTT Simulator — Environment Variables
# Copy to .env and fill in PGPASSWORD before running.
# See Bootstrap §4 for full descriptions.

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=caro-simulator

# PostgreSQL (consumed by @caro/db)
PGHOST=localhost
PGPORT=5432
PGDATABASE=caro_dev
PGUSER=postgres
PGPASSWORD=          # required — no default

# Simulation
TICK_INTERVAL_MS=100
CMD_ACK_DELAY_MS=200
SINE_PERIOD_S=30

# Control API
CONTROL_PORT=4000
LOG_BUFFER_SIZE=200

# Telemetry encoding: 'protobuf' | 'json'
TELEMETRY_ENCODING=protobuf

# Set to true to reject all SET_VALUES commands (tests OUT_OF_SYNC behaviour)
REJECT_ALL_WRITES=false
