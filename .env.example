# Tag Registry Server Configuration
PORT=3001
TEMPLATES_DIR=./apps/tag-registry/templates
MAX_TAG_PATH_LENGTH=100

# Optional Parent Type Validation
# Comma-separated template_type values each tag must have as an ancestor
VALIDATE_REQUIRED_PARENT_TYPES=

# If true, no tag may have more than one ancestor of the same template_type
VALIDATE_UNIQUE_PARENT_TYPES=false

# Phase 2 Only - DO NOT USE IN PHASE 1
# DATABASE_URL=
